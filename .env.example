# Copia este archivo a .env y pega los valores de Firebase → ⚙️ Configuración del proyecto → Tus apps → SDK
# Reinicia Expo (npx expo start) después de guardar.
#
# --- EAS Build (APK/IPA en la nube) ---
# El servidor de build NO tiene tu .env local. Crea las MISMAS variables en:
# https://expo.dev → tu proyecto → Environment variables
# Entorno: Preview (para perfil "preview") o Production (para "production")
# Visibilidad: Plain text (EXPO_PUBLIC_* son públicas en el bundle de todas formas)

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_DATABASE_URL=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=
